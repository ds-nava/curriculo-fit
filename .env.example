# API Keys dos Provedores Seguros do Servidor
GEMINI_API_KEY=sua-chave-do-google-gemini
GROQ_API_KEY=sua-chave-do-groq

# Modelos dos Provedores (Opcionais - Descomente e altere apenas se quiser mudar o modelo padrão do sistema)
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30
JOB_FETCHER_TIMEOUT_SECONDS=15
JOB_FETCHER_RETRY_MAX_ATTEMPTS=3
JOB_FETCHER_RETRY_BACKOFF_MS=400

# Frontend
VITE_API_BASE_URL=http://localhost:8080
